{
  "name": "phyrexian-arena-app",
  "version": "4.3.0",
  "private": true,
  "main": "expo-router/entry",
  "scripts": {
    "start": "expo start",
    "dev": "node scripts/adb-reverse.mjs && expo start",
    "dev:reset": "node scripts/reset-metro.mjs && node scripts/adb-reverse.mjs && expo start --clear",
    "dev:android": "node scripts/adb-reverse.mjs && node scripts/start-android.mjs",
    "android": "expo run:android",
    "android:prebuild": "expo prebuild --platform android --clean",
    "android:refresh-icons": "npm run assets:logo && npm run assets:android-icon && npm run verify:logos && npm run android:prebuild",
    "android:clean-native": "npm run android:stop-gradle && node scripts/clean-native-build.mjs",
    "android:stop-gradle": "cd android && gradlew.bat --stop && cd ..",
    "android:clean": "npm run android:stop-gradle && cd android && gradlew.bat clean --no-build-cache && cd ..",
    "android:install": "adb install -r android/app/build/outputs/apk/debug/app-debug.apk",
    "android:open": "adb shell am start -n com.phyrexianarena.app/.MainActivity",
    "lint": "expo lint",
    "typecheck": "tsc --noEmit",
    "test": "vitest run && npm run verify:logos",
    "assets:mana": "node scripts/fetch-mana-symbols.mjs",
    "assets:logo": "node scripts/flatten-logo.mjs",
    "assets:android-icon": "node scripts/generate-android-icon.mjs",
    "verify:logos": "node scripts/verify-logos.mjs",
    "eas:login": "npx eas-cli login",
    "eas:init": "npx eas-cli init",
    "eas:build:preview": "npx eas-cli build --platform android --profile preview",
    "eas:build:production": "npx eas-cli build --platform android --profile production",
    "eas:env:push": "npx eas-cli env:push --environment preview --path .env --non-interactive",
    "eas:build:preview:nowait": "npx eas-cli build --platform android --profile preview --non-interactive --no-wait"
  },
  "dependencies": {
    "@expo/vector-icons": "^14.1.0",
    "@hcaptcha/react-native-hcaptcha": "^2.1.0",
    "@react-native-async-storage/async-storage": "2.1.2",
    "@react-navigation/native": "^7.1.6",
    "@supabase/supabase-js": "^2.58.0",
    "expo": "~53.0.12",
    "expo-asset": "~11.1.7",
    "expo-constants": "~17.1.8",
    "expo-crypto": "~14.1.5",
    "expo-file-system": "~18.1.11",
    "expo-font": "~13.3.1",
    "expo-haptics": "~14.1.4",
    "expo-image": "~2.4.1",
    "expo-image-picker": "~16.1.4",
    "expo-linking": "~7.1.5",
    "expo-router": "~5.1.0",
    "expo-screen-orientation": "~8.1.7",
    "expo-secure-store": "~14.2.3",
    "expo-splash-screen": "~0.30.9",
    "expo-status-bar": "~2.2.3",
    "expo-system-ui": "~5.0.9",
    "expo-web-browser": "~14.2.0",
    "react": "19.0.0",
    "react-dom": "19.0.0",
    "react-native": "0.79.6",
    "react-native-gesture-handler": "~2.24.0",
    "react-native-get-random-values": "~1.11.0",
    "react-native-reanimated": "~3.17.4",
    "react-native-safe-area-context": "5.4.0",
    "react-native-screens": "~4.11.1",
    "react-native-url-polyfill": "^2.0.0",
    "react-native-web": "~0.20.0",
    "react-native-webview": "13.13.5"
  },
  "devDependencies": {
    "@babel/core": "^7.26.0",
    "@types/react": "~19.0.10",
    "typescript": "~5.8.3",
    "vitest": "^3.2.7"
  }
}
