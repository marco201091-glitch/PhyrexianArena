{
  "expo": {
    "name": "Phyrexian Arena",
    "slug": "phyrexian-arena",
    "version": "4.3.0",
    "platforms": ["android", "web"],
    "orientation": "default",
    "icon": "./assets/icon.png",
    "scheme": "phyrexianarena",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0a0a0f"
    },
    "android": {
      "package": "com.phyrexianarena.app",
      "versionCode": 40302,
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#000000"
      },
      "edgeToEdgeEnabled": true,
      "softwareKeyboardLayoutMode": "resize",
      "intentFilters": [
        {
          "action": "VIEW",
          "category": ["BROWSABLE", "DEFAULT"],
          "data": [
            {
              "scheme": "phyrexianarena",
              "host": "callback"
            }
          ]
        },
        {
          "action": "VIEW",
          "autoVerify": true,
          "data": [
            {
              "scheme": "https",
              "host": "phyrexian-arena.vercel.app",
              "pathPrefix": "/join"
            },
            {
              "scheme": "https",
              "host": "phyrexian-arena.vercel.app",
              "pathPrefix": "/auth/reset-password"
            },
            {
              "scheme": "https",
              "host": "phyrexian-arena.vercel.app",
              "pathPrefix": "/arena"
            },
            {
              "scheme": "https",
              "host": "phyrexian-arena.vercel.app",
              "pathPrefix": "/table"
            }
          ],
          "category": [
            "BROWSABLE",
            "DEFAULT"
          ]
        }
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-screen-orientation",
      "expo-secure-store",
      "expo-asset",
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow Phyrexian Arena to access your photos to set your profile avatar."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {
        "origin": false
      },
      "eas": {
        "projectId": "7106d709-b1a4-4fb5-a978-3465793a2015"
      }
    },
    "owner": "marcoandre91s-team"
  }
}
