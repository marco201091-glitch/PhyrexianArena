# Required (client + server)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Required on server only (register API, public arena)
SUPABASE_SERVICE_ROLE_KEY=

# Required for registration captcha
NEXT_PUBLIC_HCAPTCHA_SITE_KEY=
HCAPTCHA_SECRET_KEY=

# Required for auth emails (signup confirmation + password reset via Resend API)
RESEND_API_KEY=
RESEND_FROM_EMAIL=Phyrexian Arena <noreply@your-domain.com>

# Public site URL used in auth email links (set per Dokploy environment)
NEXT_PUBLIC_SITE_URL=

# Optional: Supabase personal access token for scripts/configure-auth-deployment.mjs
SUPABASE_ACCESS_TOKEN=

# Platform admin (must also exist in platform_admin_emails table)
PLATFORM_ADMIN_EMAILS=
NEXT_PUBLIC_PLATFORM_ADMIN_EMAILS=

# Public support/contact email shown in legal pages
NEXT_PUBLIC_SUPPORT_EMAIL=support@phyrexianarena.dpdns.org
