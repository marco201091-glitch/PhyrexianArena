{
  "name": "nextjs",
  "version": "4.5.1",
  "private": true,
  "scripts": {
    "dev": "node scripts/stop-dev.mjs && next dev --webpack",
    "dev:restart": "node scripts/stop-dev.mjs && next dev --webpack",
    "dev:stop": "node scripts/stop-dev.mjs",
    "build": "next build --webpack",
    "start": "next start",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:all": "vitest run && node scripts/verify-security.mjs",
    "verify:security": "node scripts/verify-security.mjs",
    "test:smoke": "node scripts/smoke-test.mjs",
    "test:import-images": "node scripts/verify-import-images.mjs",
    "sync:web-favicons": "node scripts/sync-web-favicons.mjs",
    "apply:migration-remote": "node scripts/apply-migration-remote.mjs",
    "configure:supabase-auth-redirects": "node scripts/configure-supabase-auth-redirects.mjs",
    "configure:auth-deployment": "node scripts/configure-auth-deployment.mjs",
    "sync:vercel-auth-env": "node scripts/sync-vercel-auth-env.mjs",
    "seed:demo-account": "node scripts/seed-demo-account.mjs",
    "sync:demo-env": "node scripts/sync-demo-env.mjs",
    "sync:platform-admin-env": "node scripts/sync-platform-admin-env.mjs",
    "mobile:sync": "npx cap sync android",
    "mobile:android": "npx cap open android",
    "mobile:build:debug": "cd mobile/android && gradlew.bat assembleDebug",
    "mobile:build:release": "cd mobile/android && gradlew.bat assembleRelease",
    "mobile:install:debug": "adb install -r mobile/android/app/build/outputs/apk/debug/app-debug.apk",
    "expo:start": "npm --prefix expo run start",
    "expo:android": "npm --prefix expo run android",
    "expo:ios": "npm --prefix expo run ios",
    "expo:ios:config": "npm --prefix expo run ios:config",
    "expo:typecheck": "npm --prefix expo run typecheck",
    "expo:eas:init": "npm --prefix expo run eas:init",
    "expo:eas:preview": "npm --prefix expo run eas:build:preview",
    "eas:init": "npm --prefix expo run eas:init",
    "eas:build:preview": "npm --prefix expo run eas:build:preview",
    "eas:build:ios:preview": "npm --prefix expo run eas:build:ios:preview",
    "eas:build:ios:unsigned": "npm --prefix expo run eas:build:ios:unsigned",
    "eas:build:ios:production": "npm --prefix expo run eas:build:ios:production",
    "eas:env:push": "npm --prefix expo run eas:env:push",
    "eas:build:preview:nowait": "npm --prefix expo run eas:build:preview:nowait"
  },
